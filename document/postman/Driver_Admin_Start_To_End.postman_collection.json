                },
                {
                  "key": "proofOfAddress",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/admin/drivers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers"
              ]
            },
            "description": "Multipart create request matching the Add Driver frontend page. File fields are optional unless backend validation requires them."
          }
        },
        {
          "name": "Update Driver Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"David\",\n  \"middleName\": \"\",\n  \"lastName\": \"\",\n  \"name\": \"David\",\n  \"email\": \"david2@millionhits.com.au\",\n  \"phone\": \"0401234578\",\n  \"phoneNumber\": \"0401234578\",\n  \"dob\": \"1990-06-09\",\n  \"addressLine1\": \"123 Test Street\",\n  \"addressLine2\": \"Unit 1\",\n  \"city\": \"Melbourne\",\n  \"state\": \"Victoria\",\n  \"postalCode\": \"3000\",\n  \"zipCode\": \"3000\",\n  \"country\": \"Australia\",\n  \"driverLicenceNumber\": \"DL-POSTMAN-001\",\n  \"licenceExpiry\": \"2027-12-31\",\n  \"passportNumber\": \"P1234567\",\n  \"visaExpiry\": \"2027-12-31\",\n  \"abn\": \"12 345 678 901\",\n  \"accountStatus\": \"Active\",\n  \"kycStatus\": \"Pending\",\n  \"reasonForChange\": \"Postman profile update test\",\n  \"personalInformation\": {\n    \"firstName\": \"David\",\n    \"middleName\": \"\",\n    \"lastName\": \"\",\n    \"email\": \"david2@millionhits.com.au\",\n    \"phone\": \"0401234578\",\n    \"dob\": \"1990-06-09\"\n  },\n  \"addressInformation\": {\n    \"addressLine1\": \"123 Test Street\",\n    \"addressLine2\": \"Unit 1\",\n    \"city\": \"Melbourne\",\n    \"state\": \"Victoria\",\n    \"postalCode\": \"3000\",\n    \"country\": \"Australia\"\n  },\n  \"documentInformation\": {\n    \"driverLicenceNumber\": \"DL-POSTMAN-001\",\n    \"licenceExpiryDate\": \"2027-12-31\",\n    \"passportNumber\": \"P1234567\",\n    \"visaExpiryDate\": \"2027-12-31\",\n    \"abn\": \"12 345 678 901\"\n  },\n  \"systemInformation\": {\n    \"accountStatus\": \"Active\",\n    \"kycStatus\": \"Pending\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}"
              ]
            },
            "description": "Used by /drivers/:id/edit Save Changes. Backend should save the changed fields and log reasonForChange into edit history."
          }
        },
        {
          "name": "Get Driver Edit History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}/edit-history?page=1&limit=25",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}",
                "edit-history"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            },
            "description": "Recommended endpoint for View Edit History. If backend has not implemented it yet, this should return 404 until added."
          }
        }
      ]
    },
    {
      "name": "03 - Documents And KYC",
      "item": [
        {
          "name": "Get Driver Documents",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const firstDoc = json?.data?.documents?.[0];",
                  "if (firstDoc?.id || firstDoc?._id) {",
                  "  pm.collectionVariables.set('documentId', firstDoc.id || firstDoc._id);",
                  "  pm.environment.set('documentId', firstDoc.id || firstDoc._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}/documents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}",
                "documents"
              ]
            },
            "description": "Used by Driver Documents tab. Expected data: { documents, internalNotes, summary }."
          }
        },
        {
          "name": "Approve Driver Document",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Approved\",\n  \"reason\": \"Verified in Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}/documents/{{documentId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}",
                "documents",
                "{{documentId}}",
                "status"
              ]
            },
            "description": "Updates one driver document status. Use status Approved, Rejected, Pending, or whatever enum backend supports."
          }
        },
        {
          "name": "Reject Driver Document",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Rejected\",\n  \"reason\": \"Document is blurry\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}/documents/{{documentId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}",
                "documents",
                "{{documentId}}",
                "status"
              ]
            },
            "description": "Rejects one driver document with reason."
          }
        },
        {
          "name": "Add Driver Internal Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Postman note: contacted driver about document renewal.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}/notes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}",
                "notes"
              ]
            },
            "description": "Adds an internal admin note for a driver."
          }
        },
        {
          "name": "Get KYC Queue",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/kyc/queue?page=1&limit=25&status=Pending",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "kyc",
                "queue"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "25"
                },
                {
                  "key": "status",
                  "value": "Pending"
                }
              ]
            },
            "description": "Used by KYC queue. Change status to All/Approved/Rejected/Pending if backend supports those values."
          }
        }
      ]
    },
    {
      "name": "04 - Export",
      "item": [
        {
          "name": "Export Drivers CSV",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"csv\",\n  \"fields\": [\n    \"driverId\",\n    \"name\",\n    \"email\",\n    \"phone\",\n    \"kycStatus\",\n    \"accountStatus\",\n    \"createdAt\"\n  ],\n  \"filters\": {\n    \"status\": \"All Status\",\n    \"kycStatus\": \"All KYC\",\n    \"paymentStatus\": \"All Payments\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/export/drivers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "export",
                "drivers"
              ]
            },
            "description": "Downloads CSV/Excel/PDF depending on backend support. In Postman, use Send and Download if response is a file."
          }
        },
        {
          "name": "Get Export History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/export/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "export",
                "history"
              ]
            },
            "description": "Returns previous export jobs/history."
          }
        }
      ]
    }
  ]
}
