{
  "info": {
    "_postman_id": "f1b7e1f8-4b30-4d36-8d5e-driver-admin-flow",
    "name": "iRent Admin - Driver Flow Start To End",
    "description": "Postman collection for the admin driver module used by the admin frontend. Run Login first, then run the driver requests in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{adminToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://skyglobal-server.onrender.com/api/v1",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@example.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "password",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "driverId",
      "value": "6a279251de01546cb1d641ec",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const token = json?.data?.token || json?.token || json?.accessToken;",
                  "if (token) {",
                  "  pm.collectionVariables.set('adminToken', token);",
                  "  pm.environment.set('adminToken', token);",
                  "}",
                  "pm.test('Token saved', function () {",
                  "  pm.expect(token, 'token').to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "auth",
                "login"
              ]
            },
            "description": "Use the same admin login endpoint as the frontend signin page. The test script stores data.token into adminToken."
          }
        }
      ]
    },
    {
      "name": "01 - Driver List And Profile",
      "item": [
        {
          "name": "Get Driver Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/drivers?limit=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "1"
                }
              ]
            },
            "description": "Frontend uses this to get driver stats. Expected data.stats includes totalDrivers, activeDrivers, suspended, pendingVerification, overduePayments, expiringLicence, expiringVisa."
          }
        },
        {
          "name": "List Drivers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const first = json?.data?.drivers?.[0] || json?.drivers?.[0];",
                  "if (first?._id || first?.driverId || first?.id) {",
                  "  pm.collectionVariables.set('driverId', first._id || first.driverId || first.id);",
                  "  pm.environment.set('driverId', first._id || first.driverId || first.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/drivers?page=1&limit=25",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            },
            "description": "Lists drivers for /drivers table. Test script stores the first returned driver id into driverId."
          }
        },
        {
          "name": "Search Drivers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/drivers?page=1&limit=25&search=David&status=Active&kycStatus=Pending",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "25"
                },
                {
                  "key": "search",
                  "value": "David"
                },
                {
                  "key": "status",
                  "value": "Active"
                },
                {
                  "key": "kycStatus",
                  "value": "Pending"
                }
              ]
            },
            "description": "Same filters used by the frontend: search, status, kycStatus, agreementStatus, paymentStatus."
          }
        },
        {
          "name": "Get Driver Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/drivers/{{driverId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "drivers",
                "{{driverId}}"
              ]
            },
            "description": "Used by /drivers/:id and /drivers/:id/edit. Frontend supports either data: driver or data: { driver }."
          }
        }
      ]
    },
    {
